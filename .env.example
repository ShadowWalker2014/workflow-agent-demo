# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Vercel AI Gateway (LLM routing for anthropic/*, openai/* model strings) ---
# Local dev: set an AI Gateway API key. On Vercel, OIDC is used automatically
# when the project is linked to a team with the AI Gateway enabled.
AI_GATEWAY_API_KEY=

# --- Exa (powers the web_search + research tools) ---
# https://exa.ai — required for the search / citation surfaces to have data.
EXA_API_KEY=
